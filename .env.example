# Copy this file to `.env` and adjust values before starting the stack:
#   cp .env.example .env
#
# `.env` is git-ignored — never commit real credentials.
# If no `.env` is present, the defaults below are used (dev-only).

# --- CouchDB admin credentials ---
# Used by:
#   - the database container (CouchDB itself)
#   - the backend container (to authenticate against CouchDB)
#   - database/config/init-db.sh (bootstrap on first start)
COUCHDB_USER=admin
COUCHDB_PASSWORD=password

# --- Container image source (ACR compose file) ---
ACR_REGISTRY=onconnecting.azurecr.io
IMAGE_TAG=latest

# --- Local registry (DEV compose file + dc-registry-local.yml) ---
# Address of the self-hosted insecure Docker registry on the DEV host.
# Used by:
#   - dc-plc-datalink-rfc1006-dev.yml (image: references)
#   - dc-registry-local.yml (LOCAL_REGISTRY_PORT controls the published port)
# Prerequisite: this address must be listed under "insecure-registries" in
# /etc/docker/daemon.json on every host that pushes or pulls.
LOCAL_REGISTRY=192.168.0.121:5000
LOCAL_REGISTRY_PORT=5000
