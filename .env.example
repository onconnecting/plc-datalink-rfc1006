# Copy this file to `.env` and adjust values before starting the stack:
#   cp .env.example .env
#
# `.env` is git-ignored — never commit real credentials.
# If no `.env` is present, the defaults below are used (dev-only).

# --- CouchDB admin credentials ---
# Used by:
#   - the database container (CouchDB itself)
#   - the backend container (to authenticate against CouchDB)
#   - database/config/init-db.sh (bootstrap on first start)
COUCHDB_USER=admin
COUCHDB_PASSWORD=password

# --- Container image source (only relevant for the ACR compose file) ---
ACR_REGISTRY=onconnecting.azurecr.io
IMAGE_TAG=latest
