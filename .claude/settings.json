{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "Bash(curl:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git ls-files:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git tag:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(docker compose:*)",
      "Bash(python3 -c *)",
      "Bash(python3 -m *)",
      "Bash(command -v *)",
      "Bash(npm run build)",
      "Bash(npm test:*)",
      "Bash(ng build:*)",
      "Bash(ng test:*)",
      "Edit(.claude/skills/**)",
      "Edit(.claude/rules/**)",
      "Edit(.claude/hooks/**)",
      "Read(/tmp/**)",
      "WebSearch"
    ],
    "additionalDirectories": [
      "/tmp",
      "/home/ofitz/plc-datalink-rfc1006/frontend"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/run-tests-on-edit.sh"
          }
        ]
      }
    ]
  }
}
