root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.py]
indent_size = 4

[*.{yml,yaml,json,ts,tsx,js,html,css,scss}]
indent_size = 2

[*.{sh,bash}]
indent_size = 2

[Makefile]
indent_style = tab

[Dockerfile,dockerfile-*]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
