# Ignore files generated by IDEs or text editors
.vscode/
.idea/
*.iml
*.ipr
*.iws
*.swp
*.swo

# Python build & cache artifacts
*.pyc
*.pyo
__pycache__/
.venv/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/

# Node / Angular build artifacts
node_modules/
frontend/dist/
frontend-next/dist/
.angular/

# Ignore environment specific files
*.env

# Ignore any other build or temporary files
*.log
.DS_Store

# Claude Code configuration
# Ignore everything under .claude/ by default …
.claude/*
# … but track the project-shared parts (skills, rules, hooks, settings.json).
# Per-developer state (projects/, todos/, cache/, local.settings.json) stays ignored
# because it never appears at .claude/<dir>/ but elsewhere or as personalised files.
!.claude/skills/
!.claude/rules/
!.claude/hooks/
!.claude/settings.json
# Local overrides remain per-developer.
.claude/settings.local.json

# Ignore internal design docs
docs/design/onconnecting-ci/
