{
  "name": "plc-datalink-rfc1006-frontend-next",
  "version": "0.0.0",
  "private": true,
  "description": "PLC Datalink RFC1006 frontend (Angular 19 LTS, onconnecting CI). Greenfield rewrite per ADR-0003 / ADR-0004.",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:int": "jest --config jest.config.int.js",
    "test:ci": "jest --ci --runInBand && jest --config jest.config.int.js --ci",
    "lint": "npm run lint:ts && npm run lint:css",
    "lint:ts": "ng lint",
    "lint:css": "stylelint \"src/**/*.css\"",
    "format": "prettier --write \"src/**/*.{ts,html,css,json}\""
  },
  "dependencies": {
    "@angular/animations": "^19.2.0",
    "@angular/cdk": "^19.2.0",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.0",
    "@angular-eslint/builder": "^19.0.0",
    "@angular-eslint/schematics": "^19.0.0",
    "@angular/build": "^19.2.0",
    "@angular/cli": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "@eslint/js": "^9.16.0",
    "@types/jest": "^30.0.0",
    "angular-eslint": "^19.0.0",
    "eslint": "^9.16.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-preset-angular": "^14.5.0",
    "prettier": "^3.4.0",
    "stylelint": "^16.11.0",
    "stylelint-config-standard": "^36.0.1",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.18.0"
  }
}
