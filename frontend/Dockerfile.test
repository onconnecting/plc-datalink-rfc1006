FROM node:26-alpine

WORKDIR /app

# Install all deps (including jest, jest-preset-angular, @types/jest, jest-environment-jsdom).
# package-lock.json is intentionally absent on this branch — `npm install` is the documented path.
COPY package.json /app/
RUN npm install --no-audit --no-fund

# Source files are mounted read-only at runtime (see dc-plc-datalink-rfc1006-test.yml).
# Baking them in here would let stale specs ship; the mount keeps every run honest.

CMD ["npx", "jest", "--ci", "--colors"]
